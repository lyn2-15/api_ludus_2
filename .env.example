# === LudusAcademia v2.1 — Variables de entorno ===

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# SQLite — en Render apunta al Persistent Disk
DATABASE_PATH=./ludusacademia.db

# Supabase (Dashboard → Project Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_JWT_SECRET=tu-jwt-secret-de-supabase-aqui

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://dashboard.ludusacademia.edu.mx

# Límites
MAX_SYNC_PAYLOAD_KB=50
INVITE_CODE_EXPIRY_HOURS=24
